   "source": [
    "num=input(\"Enter the number:\")\n",
    "rev=\"\"\n",
    "for i in num:\n",
    "    rev=i+rev\n",
    "if num==rev:\n",
    "    print(\"Palindrome\")\n",
    "else:\n",
    "    print(\"not palindrome:\")"
   ]
